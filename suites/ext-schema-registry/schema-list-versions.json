{
  "test_id": "EXT-SCH-004",
  "level": 0,
  "category": "ext-schema-registry",
  "name": "schema-list-versions",
  "description": "Register multiple schema versions for a job type and list them. Verify all versions are returned.",
  "spec_ref": "ojs-schema-registry#section-4",
  "tags": ["extension", "schema-registry", "list-versions", "happy-path"],
  "steps": [
    {
      "id": "step-1",
      "action": "PUT",
      "intent": "register-v1",
      "path": "/ojs/v1/admin/schemas/data.import/1",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "schema": {
          "type": "array",
          "items": [{ "type": "string" }]
        }
      },
      "assertions": {
        "status": { "$in": [200, 201] }
      }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "register-v2",
      "path": "/ojs/v1/admin/schemas/data.import/2",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "schema": {
          "type": "array",
          "items": [
            { "type": "string" },
            { "type": "object" }
          ]
        }
      },
      "assertions": {
        "status": { "$in": [200, 201] }
      }
    },
    {
      "id": "step-3",
      "action": "GET",
      "intent": "list-versions",
      "path": "/ojs/v1/admin/schemas/data.import/versions",
      "headers": {
        "Accept": "application/json"
      },
      "assertions": {
        "status": 200
      }
    }
  ]
}

{
  "test_id": "EXT-SCH-005",
  "level": 0,
  "category": "ext-schema-registry",
  "name": "schema-delete",
  "description": "Register a schema version, delete it, and verify it is gone.",
  "spec_ref": "ojs-schema-registry#section-4",
  "tags": ["extension", "schema-registry", "delete", "happy-path"],
  "steps": [
    {
      "id": "step-1",
      "action": "PUT",
      "intent": "register",
      "path": "/ojs/v1/admin/schemas/temp.cleanup/1",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "schema": {
          "type": "array",
          "items": [{ "type": "string" }]
        }
      },
      "assertions": {
        "status": { "$in": [200, 201] }
      }
    },
    {
      "id": "step-2",
      "action": "DELETE",
      "intent": "delete-schema",
      "path": "/ojs/v1/admin/schemas/temp.cleanup/1",
      "headers": {
        "Accept": "application/json"
      },
      "assertions": {
        "status": 200
      }
    },
    {
      "id": "step-3",
      "action": "GET",
      "intent": "verify-deleted",
      "path": "/ojs/v1/admin/schemas/temp.cleanup",
      "headers": {
        "Accept": "application/json"
      },
      "assertions": {
        "status": 404
      }
    }
  ]
}

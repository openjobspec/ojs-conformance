{
  "test_id": "EXT-SCH-001",
  "level": 0,
  "category": "ext-schema-registry",
  "name": "schema-register",
  "description": "Register a JSON Schema for a job type and version. Verify the server accepts the registration and returns the schema metadata.",
  "spec_ref": "ojs-schema-registry#section-4",
  "tags": ["extension", "schema-registry", "register", "happy-path"],
  "steps": [
    {
      "id": "step-1",
      "action": "PUT",
      "intent": "register-schema",
      "path": "/ojs/v1/admin/schemas/email.send/1",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "schema": {
          "type": "array",
          "items": [
            { "type": "string", "description": "recipient email" },
            { "type": "string", "description": "template name" }
          ],
          "minItems": 2
        }
      },
      "assertions": {
        "status": { "$in": [200, 201] },
        "body": {
          "$.type": "email.send",
          "$.version": 1
        }
      }
    }
  ]
}

{
  "test_id": "EXT-SCH-010",
  "level": 0,
  "category": "ext-schema-registry",
  "name": "schema-latest-after-delete",
  "description": "Register v1 and v2, delete v2, then GET latest. Verify the server returns v1 as the new latest.",
  "spec_ref": "ojs-schema-registry#section-4",
  "tags": ["extension", "schema-registry", "delete", "latest-pointer"],
  "steps": [
    {
      "id": "step-1",
      "action": "PUT",
      "intent": "register-v1",
      "path": "/ojs/v1/admin/schemas/order.process/1",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "schema": {
          "type": "array",
          "items": [{ "type": "string" }]
        }
      },
      "assertions": {
        "status": { "$in": [200, 201] }
      }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "register-v2",
      "path": "/ojs/v1/admin/schemas/order.process/2",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "schema": {
          "type": "array",
          "items": [{ "type": "string" }, { "type": "object" }]
        }
      },
      "assertions": {
        "status": { "$in": [200, 201] }
      }
    },
    {
      "id": "step-3",
      "action": "DELETE",
      "intent": "delete-v2",
      "path": "/ojs/v1/admin/schemas/order.process/2",
      "assertions": {
        "status": 200
      }
    },
    {
      "id": "step-4",
      "action": "GET",
      "intent": "get-latest-should-be-v1",
      "path": "/ojs/v1/admin/schemas/order.process",
      "headers": {
        "Accept": "application/json"
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.version": 1
        }
      }
    }
  ]
}

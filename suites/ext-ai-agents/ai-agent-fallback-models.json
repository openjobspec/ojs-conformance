{
  "test_id": "EXT-AI-006",
  "level": 0,
  "category": "ext-ai-agents",
  "name": "ai-agent-fallback-models",
  "description": "Enqueue an AI agent job with fallback models. Verify the fallback_models array is preserved in the job envelope.",
  "spec_ref": "ojs-ai-agents#section-3",
  "tags": ["extension", "ai-agents", "fallback", "model-config"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "type": "ai.agent.chat",
        "args": [
          {
            "prompt": "Translate this text"
          }
        ],
        "options": {
          "queue": "conformance-ai-fallback"
        },
        "ext_agent_model": "gpt-4",
        "ext_agent_fallback_models": ["gpt-3.5-turbo", "claude-3-haiku"],
        "ext_agent_provider": "openai"
      },
      "assertions": {
        "status": 201,
        "body": {
          "$.job.id": { "$exists": true },
          "$.job.state": "available",
          "$.job.ext_agent_model": "gpt-4",
          "$.job.ext_agent_fallback_models": { "$size": { "$gte": 2 } }
        }
      }
    }
  ]
}

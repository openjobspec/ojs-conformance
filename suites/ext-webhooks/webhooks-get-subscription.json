{
  "test_id": "EXT-WHK-005",
  "level": 0,
  "category": "ext-webhooks",
  "name": "webhooks-get-subscription",
  "description": "GET /ojs/v1/webhooks/subscriptions/:id to retrieve a specific webhook subscription. Verify the server returns 200 with the subscription details matching what was created.",
  "spec_ref": "ojs-webhooks#section-3.2",
  "tags": ["extension", "webhooks", "get", "happy-path"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "create a subscription",
      "path": "/ojs/v1/webhooks/subscriptions",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "url": "https://example.com/webhooks/get-test",
        "events": ["job.completed"],
        "secret": "whk_test_get_001"
      },
      "assertions": {
        "status": 201,
        "body": {"$.subscription.id": {"$exists": true}}
      }
    },
    {
      "id": "step-2",
      "action": "GET",
      "intent": "retrieve the subscription by ID",
      "path": "/ojs/v1/webhooks/subscriptions/{{steps.step-1.response.body.subscription.id}}",
      "headers": {"Accept": "application/openjobspec+json"},
      "assertions": {
        "status": 200,
        "body": {
          "$.subscription.id": "{{steps.step-1.response.body.subscription.id}}",
          "$.subscription.url": "https://example.com/webhooks/get-test",
          "$.subscription.active": true
        }
      }
    }
  ]
}

{
  "test_id": "EXT-FED-005",
  "level": 4,
  "category": "ext-federation",
  "name": "federation-no-metadata",
  "description": "Enqueue a standard job without any federation metadata. Verify the server accepts it normally and no federation fields are injected.",
  "spec_ref": "ojs-federation#section-6",
  "tags": [
    "extension",
    "federation",
    "metadata"
  ],
  "steps": [
    {
      "action": "push",
      "request": {
        "type": "email.send",
        "args": [
          "user@example.com",
          "hello"
        ],
        "queue": "default"
      },
      "expect": {
        "status": 201,
        "body": {
          "type": "email.send",
          "state": "available"
        }
      },
      "store": {
        "job_id": "id"
      }
    },
    {
      "action": "get",
      "request": {
        "id": "$ref.job_id"
      },
      "expect": {
        "status": 200,
        "body": {
          "type": "email.send"
        }
      }
    }
  ]
}

{
  "test_id": "EXT-VER-003",
  "level": 0,
  "category": "ext-job-versioning",
  "name": "job-versioning-default-version",
  "description": "Enqueue a job without specifying a version. Verify the server assigns a default version (typically 1) or accepts the job without a version field.",
  "spec_ref": "ojs-job-versioning#section-3",
  "tags": ["extension", "job-versioning", "default", "edge-case"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue-no-version",
      "path": "/ojs/v1/jobs",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "type": "email.send",
        "args": [
          "user@example.com",
          "default-version-test"
        ],
        "options": {
          "queue": "conformance-versioning-default"
        }
      },
      "assertions": {
        "status": 201,
        "body": {
          "$.job.id": { "$exists": true },
          "$.job.state": "available"
        }
      }
    },
    {
      "id": "step-2",
      "action": "GET",
      "intent": "get-job",
      "path": "/ojs/v1/jobs/{{steps.step-1.response.body.job.id}}",
      "headers": {
        "Accept": "application/openjobspec+json"
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.job.id": "{{steps.step-1.response.body.job.id}}",
          "$.job.type": "email.send"
        }
      }
    }
  ]
}

{
  "test_id": "L1-WASI-002",
  "level": 1,
  "category": "wasi",
  "name": "wasi-worker-execute",
  "description": "A WASI host MUST execute the guest component's exported function with the job payload. The guest receives the job args and returns a result. This test verifies the round-trip by enqueuing a job, fetching it, and simulating execution completion.",
  "spec_ref": "ojs-ext-runtime#section-3",
  "tags": [
    "level-1",
    "wasi",
    "execute"
  ],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "headers": {
        "Content-Type": "application/openjobspec+json"
      },
      "body": {
        "type": "wasi.test.execute",
        "args": [
          {
            "action": "echo",
            "value": "hello-wasi"
          }
        ],
        "options": {
          "queue": "wasi-test"
        },
        "meta": {
          "ojs.ext_runtime": {
            "name": "wasi:ojs",
            "min": "0.1.0"
          }
        }
      },
      "assertions": {
        "status": 201,
        "body": {
          "$.job.id": "string:uuidv7",
          "$.job.state": "available"
        }
      },
      "capture": {
        "job_id": "$.job.id"
      }
    },
    {
      "id": "step-2",
      "action": "POST",
      "intent": "fetch",
      "path": "/ojs/v1/jobs/fetch",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "queues": [
          "wasi-test"
        ],
        "count": 1
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.jobs[0].type": "wasi.test.execute",
          "$.jobs[0].args[0].action": "echo",
          "$.jobs[0].args[0].value": "hello-wasi"
        }
      }
    },
    {
      "id": "step-3",
      "action": "POST",
      "intent": "ack-complete",
      "path": "/ojs/v1/jobs/${job_id}/ack",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "result": "completed"
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.job.state": "completed"
        }
      }
    }
  ]
}

{
  "test_id": "EXT-ENC-004",
  "level": 0,
  "category": "ext-encryption",
  "name": "encryption-codec-chaining",
  "description": "Enqueue a job with a codec chain (compress then encrypt) indicated by ojs_codec_chain array. Verify the server preserves the full codec chain metadata through the enqueue/fetch cycle.",
  "spec_ref": "ojs-encryption#section-6",
  "tags": ["extension", "encryption", "codec-chaining", "happy-path"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "type": "test.encrypted.chained",
        "args": [
          "Y29tcHJlc3NlZC10aGVuLWVuY3J5cHRlZA=="
        ],
        "meta": {
          "ojs_encoded": true,
          "ojs.codec.encodings": ["zstd", "aes-256-gcm"],
          "ojs.codec.key_id": "key-2024-003",
          "ojs.codec.nonce": "Y2hhaW4tbm9uY2U="
        },
        "options": {
          "queue": "conformance-encryption-chain"
        }
      },
      "assertions": {
        "status": 201,
        "body": {
          "$.job.id": { "$exists": true },
          "$.job.state": "available"
        }
      }
    },
    {
      "id": "step-2",
      "action": "POST",
      "intent": "fetch",
      "path": "/ojs/v1/workers/fetch",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "queues": ["conformance-encryption-chain"],
        "worker_id": "test-worker-enc-chain-1"
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.jobs[0].id": "{{steps.step-1.response.body.job.id}}",
          "$.jobs[0].args[0]": "Y29tcHJlc3NlZC10aGVuLWVuY3J5cHRlZA==",
          "$.jobs[0].meta.ojs_encoded": true,
          "$.jobs[0].meta.ojs.codec.encodings[0]": "zstd",
          "$.jobs[0].meta.ojs.codec.encodings[1]": "aes-256-gcm",
          "$.jobs[0].meta.ojs.codec.key_id": "key-2024-003",
          "$.jobs[0].meta.ojs.codec.nonce": "Y2hhaW4tbm9uY2U="
        }
      }
    }
  ]
}

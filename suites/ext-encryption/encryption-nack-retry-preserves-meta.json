{
  "test_id": "EXT-ENC-009",
  "level": 0,
  "category": "ext-encryption",
  "name": "encryption-nack-retry-preserves-meta",
  "description": "Enqueue an encrypted job, fetch it, NACK it (triggering retry), and verify the codec metadata is preserved through the retry cycle. The encrypted args must remain unchanged across attempts.",
  "spec_ref": "ojs-encryption#section-3",
  "tags": ["extension", "encryption", "retry", "nack"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "type": "test.encrypted.retry",
        "args": [
          "cmV0cnktcGF5bG9hZA=="
        ],
        "meta": {
          "ojs_encoded": true,
          "ojs.codec.encodings": ["binary/encrypted"],
          "ojs.codec.key_id": "retry-key-001"
        },
        "options": {
          "queue": "conformance-encryption-retry",
          "retry": {
            "max_attempts": 3,
            "strategy": "constant",
            "initial_delay_ms": 100
          }
        }
      },
      "assertions": {
        "status": 201,
        "body": {
          "$.job.id": { "$exists": true },
          "$.job.state": "available"
        }
      }
    },
    {
      "id": "step-2",
      "action": "POST",
      "intent": "fetch",
      "path": "/ojs/v1/workers/fetch",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "queues": ["conformance-encryption-retry"],
        "worker_id": "test-worker-enc-retry-1"
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.jobs[0].id": "{{steps.step-1.response.body.job.id}}",
          "$.jobs[0].state": "active",
          "$.jobs[0].meta.ojs_encoded": true,
          "$.jobs[0].meta.ojs.codec.encodings[0]": "binary/encrypted"
        }
      }
    },
    {
      "id": "step-3",
      "action": "POST",
      "intent": "nack",
      "path": "/ojs/v1/jobs/{{steps.step-1.response.body.job.id}}/nack",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "worker_id": "test-worker-enc-retry-1",
        "error": {
          "code": "handler_error",
          "message": "transient failure"
        }
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.job.state": "retryable"
        }
      }
    },
    {
      "id": "step-4",
      "action": "GET",
      "intent": "verify-meta-after-nack",
      "path": "/ojs/v1/jobs/{{steps.step-1.response.body.job.id}}",
      "headers": {
        "Accept": "application/openjobspec+json"
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.job.args[0]": "cmV0cnktcGF5bG9hZA==",
          "$.job.meta.ojs_encoded": true,
          "$.job.meta.ojs.codec.encodings[0]": "binary/encrypted",
          "$.job.meta.ojs.codec.key_id": "retry-key-001"
        }
      }
    }
  ]
}

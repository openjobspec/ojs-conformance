{
  "test_id": "L4-AGT-004",
  "level": 4,
  "category": "agent",
  "name": "Agent tool retry alternate",
  "description": "Verify TOOL_RETRY_ALTERNATE operation. Enqueues an agent job that exercises tool-call retry with an alternate provider fallback.",
  "spec_ref": "ojs-ai-agents-v2.md#tool_retry_alternate",
  "tags": ["extension", "ai-agents", "tool-retry", "fallback"],
  "steps": [
    {
      "id": "s1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "headers": {
        "Content-Type": "application/openjobspec+json",
        "Accept": "application/openjobspec+json"
      },
      "body": {
        "type": "agent.tool-retry-test",
        "args": ["call-tool"],
        "options": {
          "queue": "conformance-agent-tool-retry"
        },
        "ext_agent_v2": {
          "state": "running",
          "tool_retry": {
            "max_attempts": 3,
            "alternate_provider": "fallback-provider"
          }
        }
      },
      "assertions": {
        "status": 201,
        "body": {
          "$.job.id": { "$exists": true },
          "$.job.state": "available"
        }
      }
    },
    {
      "id": "s2",
      "action": "POST",
      "intent": "simulate tool failure and retry",
      "path": "/ojs/v1/agents/{{steps.s1.response.body.job.id}}/tool-retry",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "tool_call_id": "tc-001",
        "error": "provider timeout",
        "use_alternate": true
      },
      "assertions": {
        "status": 200,
        "body": {
          "$.retried": true,
          "$.provider": "fallback-provider"
        }
      }
    }
  ]
}

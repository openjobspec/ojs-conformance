{
  "test_id": "EXT-DUR-001",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-save-and-retrieve",
  "description": "Save a checkpoint for a job and verify it can be retrieved with correct state and sequence number.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "happy-path"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable",
        "args": ["checkpoint-test"],
        "options": { "queue": "conformance-durable" }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "save-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": { "state": { "processed": 500, "total": 1000 } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "GET",
      "intent": "get-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": {
        "status": 200,
        "body.job_id": "${job_id}",
        "body.state.processed": 500,
        "body.sequence": 1
      }
    }
  ]
}

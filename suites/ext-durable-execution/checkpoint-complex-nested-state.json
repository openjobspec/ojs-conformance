{
  "test_id": "EXT-DUR-011",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-complex-nested-state",
  "description": "Checkpoint state can contain deeply nested JSON objects, arrays, and mixed types. Verify the server preserves the full structure without loss or mutation.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "nested-state", "edge-case"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.nested",
        "args": ["nested-state-test"],
        "options": { "queue": "conformance-durable-nested" }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "save-complex-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": {
        "state": {
          "pipeline": {
            "stages": [
              { "name": "extract", "status": "completed", "rows": 15000 },
              { "name": "transform", "status": "in_progress", "rows": 8500 },
              { "name": "load", "status": "pending", "rows": 0 }
            ],
            "metadata": {
              "source": "s3://bucket/data.parquet",
              "format": "parquet",
              "compression": "snappy"
            }
          },
          "cursors": {
            "extract": "2026-03-09T20:00:00Z",
            "transform": "batch-42"
          },
          "counters": {
            "success": 8500,
            "errors": 3,
            "skipped": 12
          },
          "flags": {
            "dedup_enabled": true,
            "dry_run": false,
            "nullable_field": null
          },
          "tags": ["etl", "daily", "critical"],
          "empty_array": [],
          "empty_object": {}
        }
      },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "GET",
      "intent": "verify-nested-structure-preserved",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": {
        "status": 200,
        "body.state.pipeline.stages[0].name": "extract",
        "body.state.pipeline.stages[0].rows": 15000,
        "body.state.pipeline.stages[1].status": "in_progress",
        "body.state.pipeline.stages[2].status": "pending",
        "body.state.pipeline.metadata.format": "parquet",
        "body.state.cursors.transform": "batch-42",
        "body.state.counters.success": 8500,
        "body.state.counters.errors": 3,
        "body.state.flags.dedup_enabled": true,
        "body.state.flags.dry_run": false,
        "body.state.tags[0]": "etl",
        "body.state.tags[2]": "critical",
        "body.sequence": 1
      }
    }
  ]
}

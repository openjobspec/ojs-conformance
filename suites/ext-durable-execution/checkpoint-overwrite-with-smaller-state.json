{
  "test_id": "EXT-DUR-017",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-overwrite-with-smaller-state",
  "description": "Overwriting a checkpoint with a smaller state should fully replace the previous state. No fields from the old state should leak into the new checkpoint.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "overwrite", "regression"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.overwrite_shrink",
        "args": ["overwrite-shrink-test"],
        "options": { "queue": "conformance-durable-shrink" }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "save-large-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": {
        "state": {
          "field_a": "value_a",
          "field_b": "value_b",
          "field_c": "value_c",
          "nested": { "x": 1, "y": 2, "z": 3 }
        }
      },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "PUT",
      "intent": "overwrite-with-smaller-state",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": {
        "state": { "only_field": "new_value" }
      },
      "expect": { "status": 200 }
    },
    {
      "id": "step-4",
      "action": "GET",
      "intent": "verify-full-replacement",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": {
        "status": 200,
        "body.state.only_field": "new_value",
        "body.sequence": 2
      }
    }
  ]
}

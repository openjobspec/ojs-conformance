{
  "test_id": "EXT-DUR-002",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-sequence-increments",
  "description": "Multiple checkpoint saves for the same job should increment the sequence number.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "sequence"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.sequence",
        "args": ["seq-test"],
        "options": { "queue": "conformance-durable" }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "save-checkpoint-1",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": { "state": { "step": 1 } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "PUT",
      "intent": "save-checkpoint-2",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": { "state": { "step": 2 } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-4",
      "action": "GET",
      "intent": "verify-latest-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": {
        "status": 200,
        "body.state.step": 2,
        "body.sequence": 2
      }
    }
  ]
}

{
  "test_id": "EXT-DUR-012",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-deleted-before-resume",
  "description": "If a checkpoint is deleted before a retry, the retried job should receive no checkpoint state, forcing a fresh start. Verifies the delete-then-retry sequence.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "delete", "resume", "edge-case"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.delete_resume",
        "args": ["delete-resume-test"],
        "options": {
          "queue": "conformance-durable-delresume",
          "retry": { "max_attempts": 3, "initial_interval": "PT1S" }
        }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "POST",
      "intent": "fetch",
      "path": "/ojs/v1/workers/fetch",
      "body": { "queues": ["conformance-durable-delresume"], "worker_id": "w-delresume-1" },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "PUT",
      "intent": "save-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": { "state": { "progress": 50 } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-4",
      "action": "DELETE",
      "intent": "delete-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": { "status": 200 }
    },
    {
      "id": "step-5",
      "action": "GET",
      "intent": "verify-checkpoint-gone",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": { "status": 404 }
    },
    {
      "id": "step-6",
      "action": "POST",
      "intent": "nack-to-trigger-retry",
      "path": "/ojs/v1/workers/nack",
      "body": {
        "job_id": "${job_id}",
        "worker_id": "w-delresume-1",
        "error": { "code": "handler_error", "message": "Simulated failure after delete", "retryable": true }
      },
      "expect": { "status": 200 }
    },
    {
      "id": "step-7",
      "action": "WAIT",
      "duration_ms": 1500,
      "description": "Wait for retry delay"
    },
    {
      "id": "step-8",
      "action": "GET",
      "intent": "verify-no-checkpoint-after-retry",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": { "status": 404 }
    }
  ]
}

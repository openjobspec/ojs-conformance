{
  "test_id": "EXT-DUR-007",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-delete-idempotent",
  "description": "Deleting a checkpoint that doesn't exist (or was already deleted) should not return an error.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "delete", "idempotent"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.delete-idempotent",
        "args": ["idempotent-delete-test"],
        "options": { "queue": "conformance-durable" }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "save-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": { "state": { "data": "temporary" } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "DELETE",
      "intent": "first-delete",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": { "status": 200 }
    },
    {
      "id": "step-4",
      "action": "DELETE",
      "intent": "second-delete-idempotent",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": { "status": 200 }
    }
  ]
}

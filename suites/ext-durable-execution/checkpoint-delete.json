{
  "test_id": "EXT-DUR-003",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-delete",
  "description": "Deleting a checkpoint removes it. Subsequent GET returns 404.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "delete"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.delete",
        "args": ["del-test"],
        "options": { "queue": "conformance-durable" }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "PUT",
      "intent": "save-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": { "state": { "data": "to-delete" } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "DELETE",
      "intent": "delete-checkpoint",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": { "status": 200 }
    },
    {
      "id": "step-4",
      "action": "GET",
      "intent": "verify-deleted",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "expect": { "status": 404 }
    }
  ]
}

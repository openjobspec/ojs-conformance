{
  "test_id": "EXT-DUR-013",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-after-completion",
  "description": "Saving a checkpoint for a completed job should fail. Once a job reaches a terminal state, checkpoint operations are no longer valid.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "terminal-state", "error-handling"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.completed",
        "args": ["terminal-checkpoint-test"],
        "options": { "queue": "conformance-durable-terminal" }
      },
      "expect": { "status": 201 },
      "capture": { "job_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "POST",
      "intent": "fetch",
      "path": "/ojs/v1/workers/fetch",
      "body": { "queues": ["conformance-durable-terminal"], "worker_id": "w-terminal-1" },
      "expect": { "status": 200 }
    },
    {
      "id": "step-3",
      "action": "POST",
      "intent": "ack-to-complete",
      "path": "/ojs/v1/workers/ack",
      "body": {
        "job_id": "${job_id}",
        "worker_id": "w-terminal-1",
        "result": { "status": "done" }
      },
      "expect": { "status": 200 }
    },
    {
      "id": "step-4",
      "action": "PUT",
      "intent": "attempt-save-on-completed-job",
      "path": "/ojs/v1/jobs/${job_id}/checkpoint",
      "body": { "state": { "should_not": "be_saved" } },
      "expect": { "status": 409 }
    }
  ]
}

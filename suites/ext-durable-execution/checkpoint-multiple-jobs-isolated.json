{
  "test_id": "EXT-DUR-016",
  "level": 0,
  "category": "ext-durable-execution",
  "name": "checkpoint-multiple-jobs-isolated",
  "description": "Checkpoints for different jobs must be isolated. Saving and retrieving checkpoints for two separate jobs should return the correct state for each without cross-contamination.",
  "spec_ref": "ojs-durable-execution#section-4",
  "tags": ["extension", "durable-execution", "checkpoint", "isolation", "multi-job"],
  "steps": [
    {
      "id": "step-1",
      "action": "POST",
      "intent": "enqueue-job-a",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.isolation_a",
        "args": ["isolation-job-a"],
        "options": { "queue": "conformance-durable-iso" }
      },
      "expect": { "status": 201 },
      "capture": { "job_a_id": "$.id" }
    },
    {
      "id": "step-2",
      "action": "POST",
      "intent": "enqueue-job-b",
      "path": "/ojs/v1/jobs",
      "body": {
        "type": "test.durable.isolation_b",
        "args": ["isolation-job-b"],
        "options": { "queue": "conformance-durable-iso" }
      },
      "expect": { "status": 201 },
      "capture": { "job_b_id": "$.id" }
    },
    {
      "id": "step-3",
      "action": "PUT",
      "intent": "save-checkpoint-job-a",
      "path": "/ojs/v1/jobs/${job_a_id}/checkpoint",
      "body": { "state": { "owner": "job-a", "count": 100 } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-4",
      "action": "PUT",
      "intent": "save-checkpoint-job-b",
      "path": "/ojs/v1/jobs/${job_b_id}/checkpoint",
      "body": { "state": { "owner": "job-b", "count": 999 } },
      "expect": { "status": 200 }
    },
    {
      "id": "step-5",
      "action": "GET",
      "intent": "verify-job-a-checkpoint",
      "path": "/ojs/v1/jobs/${job_a_id}/checkpoint",
      "expect": {
        "status": 200,
        "body.state.owner": "job-a",
        "body.state.count": 100,
        "body.sequence": 1
      }
    },
    {
      "id": "step-6",
      "action": "GET",
      "intent": "verify-job-b-checkpoint",
      "path": "/ojs/v1/jobs/${job_b_id}/checkpoint",
      "expect": {
        "status": 200,
        "body.state.owner": "job-b",
        "body.state.count": 999,
        "body.sequence": 1
      }
    }
  ]
}
